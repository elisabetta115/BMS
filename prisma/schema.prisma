generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum UnitType {
  VIDEO
  QUIZ
  EXAM
  PRESENTATION
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String   @map("password_hash")
  country       String?
  role          Role     @default(USER)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  enrolledProgrammes  ProgrammeEnrollment[]
  enrolledCredentials CredentialEnrollment[]

  @@map("users")
}

model MicroCredential {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  code        String
  project     String
  description String?
  overview    String?
  objectives  String?
  image       String?
  imageData   Bytes?   @map("image_data")
  imageMime   String?  @map("image_mime")
  developedBy String?  @map("developed_by")
  passGrade   Int      @default(50) @map("pass_grade")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sections    CredentialSection[]
  programmes  ProgrammeCredential[]
  enrollments CredentialEnrollment[]

  @@map("micro_credentials")
}

model CredentialSection {
  id           String   @id @default(cuid())
  credentialId String   @map("credential_id")
  title        String
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  credential   MicroCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  subsections  CredentialSubsection[]

  @@map("credential_sections")
}

model CredentialSubsection {
  id        String   @id @default(cuid())
  sectionId String   @map("section_id")
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  section CredentialSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  units   CredentialUnit[]

  @@map("credential_subsections")
}

model CredentialUnit {
  id           String   @id @default(cuid())
  subsectionId String   @map("subsection_id")
  title        String
  type         UnitType
  order        Int      @default(0)
  weight       Int      @default(0)
  videoUrl     String?  @map("video_url")
  fileData     Bytes?   @map("file_data")
  fileMime     String?  @map("file_mime")
  fileName     String?  @map("file_name")
  createdAt    DateTime @default(now()) @map("created_at")

  subsection CredentialSubsection @relation(fields: [subsectionId], references: [id], onDelete: Cascade)
  questions  UnitQuestion[]

  @@map("credential_units")
}

model UnitQuestion {
  id           String   @id @default(cuid())
  unitId       String   @map("unit_id")
  question     String
  options      String[]
  correctIndex Int      @map("correct_index")
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  unit CredentialUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@map("unit_questions")
}

model MicroProgramme {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  code        String
  project     String
  description String?
  image       String?
  imageData   Bytes?   @map("image_data")
  imageMime   String?  @map("image_mime")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  credentials ProgrammeCredential[]
  enrollments ProgrammeEnrollment[]

  @@map("micro_programmes")
}

model ProgrammeCredential {
  programmeId  String @map("programme_id")
  credentialId String @map("credential_id")
  order        Int    @default(0)

  programme  MicroProgramme  @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  credential MicroCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@id([programmeId, credentialId])
  @@map("programme_credentials")
}

model ProgrammeEnrollment {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  programmeId String   @map("programme_id")
  enrolledAt  DateTime @default(now()) @map("enrolled_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  programme MicroProgramme @relation(fields: [programmeId], references: [id], onDelete: Cascade)

  @@unique([userId, programmeId])
  @@map("programme_enrollments")
}

model CredentialEnrollment {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  credentialId String   @map("credential_id")
  enrolledAt   DateTime @default(now()) @map("enrolled_at")

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  credential MicroCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@unique([userId, credentialId])
  @@map("credential_enrollments")
}